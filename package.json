{
  "name": "cucumber-reports",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "fix": "biome check --fix --error-on-warnings",
    "lint": "biome check --error-on-warnings",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:acceptance": "node --import @cucumber/node/bootstrap --import tsx --test-concurrency=3 --test \"features/**/*.feature\""
  },
  "dependencies": {
    "@cucumber/messages": "^32.3.1",
    "@cucumber/react-components": "^24.3.0",
    "@hyperjump/browser": "^1.3.1",
    "@hyperjump/json-schema": "^1.17.6",
    "@sentry/react": "^10.30.0",
    "@tanstack/react-query": "^5.85.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cloudflare/vite-plugin": "^1.33.2",
    "@cloudflare/workers-types": "^4.20260424.1",
    "@cucumber/biome-config": "github:cucumber/biome-config#v0.2.1",
    "@cucumber/node": "^0.7.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "puppeteer": "^25.0.0",
    "sass-embedded": "^1.91.0",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.19.3",
    "typescript": "~5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.85.0"
  }
}
